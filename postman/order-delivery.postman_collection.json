{
  "info": {
    "name": "Event-Driven Order Delivery System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "restaurantId", "value": "" },
    { "key": "menuItemId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "agentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Admin One\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"ADMIN\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Create Restaurant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/restaurants",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Dinesh Biryani House\",\n  \"cuisine\": \"Indian\",\n  \"location\": \"Hyderabad\",\n  \"address\": \"Hitech City Road\",\n  \"active\": true\n}"
        }
      }
    },
    {
      "name": "Add Menu Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/restaurants/{{restaurantId}}/menu",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Chicken Biryani\",\n  \"description\": \"Slow cooked biryani with raita\",\n  \"price\": 249.00,\n  \"available\": true\n}"
        }
      }
    },
    {
      "name": "Search Restaurants",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/restaurants?query=biryani&location=Hyderabad"
      }
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"deliveryAddress\": \"Flat 42, Jubilee Hills\",\n  \"items\": [\n    { \"menuItemId\": \"{{menuItemId}}\", \"quantity\": 2 }\n  ]\n}"
        }
      }
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/orders/{{orderId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
        }
      }
    },
    {
      "name": "Simulate Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/payments/{{orderId}}/simulate",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"success\": true\n}"
        }
      }
    },
    {
      "name": "Assign Delivery",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/deliveries/{{orderId}}/assign",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agentId\": \"{{agentId}}\",\n  \"estimatedMinutes\": 35\n}"
        }
      }
    },
    {
      "name": "Update Delivery Status",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/deliveries/{{orderId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PICKED_UP\"\n}"
        }
      }
    },
    {
      "name": "Refund Payment",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/payments/{{orderId}}/refund"
      }
    },
    {
      "name": "Admin Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/admin/dashboard"
      }
    },
    {
      "name": "Admin Event Audit",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/admin/events"
      }
    }
  ]
}

